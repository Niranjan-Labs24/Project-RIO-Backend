generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7 removed `url` from the schema's datasource block. The CLI
  // (migrate/seed) now reads DATABASE_URL (the cnap_owner role) from
  // prisma.config.ts. The running app overrides the connection at runtime
  // with a driver adapter built from APP_DATABASE_URL (cnap_app) in
  // PrismaService.
  provider = "postgresql"
}

enum Sector {
  education
  healthcare
  agriculture
  wash
  livelihoods
  disaster_relief
  other
}

enum UserStatus {
  active
  invited
}

enum PermissionModule {
  entityTeam
  rolesPermissions
  onboardingConsent
  methodologyQuestionBank
  studySurvey
  dataCollection
  dataImport
  citizenChannel
  aiReview
  priorityScoring
  reportsDashboards
  archiveSharingAudit
  // Survey Builder (Question Bank + AI-assisted questionnaire design) is its
  // own independent methodology feature, not a Study feature — deliberately
  // not folded into studySurvey. Publish Survey/QR and the Citizen public
  // flow are unrelated and keep using their own existing modules.
  surveyBuilder
}

// ──────── Reference (global, seeded, read-only to cnap_app) ────────
model Role {
  id          String  @id @db.VarChar(64) // stable seeded id "role_<key>" (matches the FE)
  key         String  @unique @db.VarChar(64)
  name        String  @db.VarChar(120)
  description String
  crossEntity Boolean @map("cross_entity")

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model RolePermission {
  id      String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  roleId  String           @map("role_id") @db.VarChar(64)
  module  PermissionModule
  read    Boolean          @default(false)
  write   Boolean          @default(false)
  create  Boolean          @default(false)
  approve Boolean          @default(false)
  export  Boolean          @default(false)
  share   Boolean          @default(false)

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, module])
  @@map("role_permissions")
}

model ConsentPolicy {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  version   String   @unique @db.VarChar(64)
  text      String
  active    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("consent_policies")
}

// ──────── Tenancy & identity ────────
model Organisation {
  id                 String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name               String   @db.VarChar(200)
  purpose            String?  @db.VarChar(500)
  registrationNumber String?  @unique @map("registration_number") @db.VarChar(100)
  // A org can span more than one region — same array-of-strings shape as
  // `villages` below, not a single free-text field (was `String?` — a
  // comma-separated "Region A, Region B" entry used to be stored as one
  // literal string instead of being treated as multiple regions).
  region             String[] @default([])
  email              String?  @db.VarChar(320)
  sector             Sector?
  logoUrl            String?  @map("logo_url")
  villages           String[] @default([])
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users                  User[]
  consents               ConsentAcceptance[]
  auditLogs              AuditLog[]
  studies                Study[]
  needs                  Need[]
  evidence               Evidence[]
  aiDecisions            AiDecision[]
  surveyLinks            PublicSurveyLink[]
  otpChallenges          CitizenOtpChallenge[]
  surveyResponses        SurveyResponse[]
  responseQualityResults ResponseQualityResult[]
  aiSummaries AiSummary[]
  priorityScores PriorityScore[]
  sharingRequestsOwned SharingRequest[] @relation("SharingRequestsOwned")
  sharingRequestsMade  SharingRequest[] @relation("SharingRequestsMade")
  reports Report[]
  aiSuggestions AiSuggestion[]
  humanDecisions HumanDecision[]
  surveys Survey[]

  @@map("organisations")
}

model User {
  id                     String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId                  String     @map("org_id") @db.Uuid
  roleId                 String     @map("role_id") @db.VarChar(64)
  name                   String     @db.VarChar(200)
  email                  String     @unique @db.VarChar(320)
  status                 UserStatus @default(invited)
  passwordHash           String?    @map("password_hash") @db.VarChar(255)
  mustChangePassword     Boolean    @default(false) @map("must_change_password")
  consentedAt            DateTime?  @map("consented_at") @db.Timestamptz(6)
  // The policy version accepted at `consentedAt` — kept alongside the
  // timestamp (denormalized from ConsentAcceptance) so a version bump can be
  // detected on every login/me() without an extra join. The full acceptance
  // history still lives in ConsentAcceptance; this is just "what's current."
  consentedPolicyVersion String?    @map("consented_policy_version") @db.VarChar(64)
  failedLoginAttempts    Int        @default(0) @map("failed_login_attempts")
  sessionVersion         Int        @default(0) @map("session_version")
  lockedUntil            DateTime?  @map("locked_until") @db.Timestamptz(6)
  lastLoginAt            DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt              DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  org              Organisation        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role             Role                @relation(fields: [roleId], references: [id])
  consents         ConsentAcceptance[]
  // Studies this user is the assigned reviewer for (see Study.assignedReviewerId).
  reviewingStudies Study[]             @relation("StudyAssignedReviewer")
  @@index([orgId])
  @@index([roleId])
  @@map("users")
}

model ConsentAcceptance {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  policyVersion String   @map("policy_version") @db.VarChar(64)
  policyText    String   @map("policy_text")
  acceptedAt    DateTime @default(now()) @map("accepted_at") @db.Timestamptz(6)

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("consent_acceptances")
}

model AuditLog {
  id             String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  organisationId String?  @map("organisation_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String   @db.VarChar(64)
  entityType     String   @map("entity_type") @db.VarChar(64)
  entityId       String?  @map("entity_id") @db.Uuid
  entityLabel    String   @map("entity_label")
  metadata       Json?
  ipAddress      String?  @map("ip_address") @db.VarChar(64)
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org Organisation? @relation(fields: [organisationId], references: [id])

  @@index([organisationId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ──────── Week 2: Data Capture (RIO-FR-001, RIO-FR-Add-01, RIO-FR-003) ────────

// Matches the RIO-FR-001/Add-01/003 flow: draft -> need_captured ->
// evidence_submitted -> ai_classified -> human_reviewed. Uploading evidence
// no longer advances status by itself — a researcher must
// explicitly submit (EvidenceService.submit) before AI Classification is
// allowed to run; that submit action is what sets evidence_submitted.
// Stops there deliberately — survey_ready/published/archived belong to
// Survey Builder/Reports, out of scope for Week 2.
enum StudyStatus {
  draft
  need_captured
  evidence_submitted
  ai_classified
  human_reviewed
}

model Study {
  id                 String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId              String      @map("org_id") @db.Uuid
  title              String      @db.VarChar(300)
  // Selected from (or added alongside) the org's own configured villages
  // list — same array-of-strings shape as Organisation.villages, not a
  // master-data table, per the same "don't promote to master data" call
  // made for Need.village.
  villages  String[]    @default([])
  status    StudyStatus @default(draft)
  // AI Classification's suggested/confirmed Domain + Sub-Domain for this
  // Study (see the Domain/SubDomain reference tables) — set once a human
  // approves an AI Classification decision on this Study's Need (see
  // AiDecisionsService.review). Nullable until then.
  domain           String? @db.VarChar(120)
  subDomain        String? @map("sub_domain") @db.VarChar(120)
  createdBy String      @map("created_by") @db.Uuid
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  need     Need?
  evidence Evidence[]
  aiDecisions AiDecision[]
  surveyLinks PublicSurveyLink[]
  surveyResponses SurveyResponse[]
  responseQualityResults ResponseQualityResult[]
  aiSummaries AiSummary[]
  priorityScores PriorityScore[]
  sharingRequests SharingRequest[]
  reports Report[]
  aiSuggestions AiSuggestion[]
  humanDecisions HumanDecision[]
  surveys Survey[]

  @@index([orgId])
  @@map("studies")
}

// RIO-FR-001: a Study contains exactly one Need — enforced here via the
// unique studyId (1:1 at the DB level, not just app-level convention).
model Need {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  studyId   String   @unique @map("study_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  title     String   @db.VarChar(300)
  statement String
  // A Need can name more than one village — same array-of-strings shape as
  // Organisation.villages (was `String` — a comma-separated "Village A,
  // Village B" entry used to be stored as one literal string instead of
  // being treated as multiple villages). Do not promote this to a
  // master-data table without an explicit ticket.
  village   String[] @default([])
  // System-set (e.g. "manual_entry"), never client-writable — set by the
  // service based on the creation path, not accepted in CreateNeedBody.
  source    String   @db.VarChar(200)
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  study Study        @relation(fields: [studyId], references: [id], onDelete: Cascade)
  org   Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("needs")
}

// RIO-FR-Add-01: multiple files per Study, uploaded after the Need exists.
// storageKey is a local disk path for Phase 1 — kept as a plain string so
// swapping to an object-storage key later needs no schema change.
model Evidence {
  id         String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  studyId    String   @map("study_id") @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  fileName   String   @map("file_name") @db.VarChar(255)
  fileType   String   @map("file_type") @db.VarChar(100)
  fileSize   Int      @default(0) @map("file_size")
  storageKey String   @map("storage_key") @db.VarChar(500)
  // sha256 of the uploaded file's bytes, hex-encoded (64 chars) — computed
  // once from the in-memory upload buffer, never re-read from storageKey.
  //
  // Nullable *because* of that: rows written before this column existed have
  // no buffer to hash and can't be backfilled from SQL, so they keep a null
  // hash and simply never take part in duplicate detection. Every row created
  // from now on has one. Don't tighten this to NOT NULL without first
  // backfilling by re-reading each storageKey off disk — which is exactly
  // what the line above says this hash never does.
  fileHash   String?  @map("file_hash") @db.VarChar(64)
  uploadedBy String   @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  study Study        @relation(fields: [studyId], references: [id], onDelete: Cascade)
  org   Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([studyId])
  @@index([orgId])
  @@index([studyId, fileHash])
  @@map("evidence")
}

// RIO-FR-003: only the two touchpoints Week 2 produces a placeholder for.
// More values (evidence_summary, report_summary, etc.) get added later by
// whichever team builds those stages.
enum AiTouchpoint {
  need_classification
  priority_scoring
}

// One generic table for every AI touchpoint — AI suggestion and human
// override are separate columns on the same row (auditable, explainable),
// not a separate table per touchpoint.
//
// TODO(RIO-FR-003): `suggestion`'s shape and how `confidence` is computed
// are both placeholders pending the buyer-provided methodology package —
// see ai-decisions/classification.placeholder.ts.
model AiDecision {
  id            String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  studyId       String       @map("study_id") @db.Uuid
  touchpoint    AiTouchpoint
  subjectType   String       @map("subject_type") @db.VarChar(100)
  subjectId     String       @map("subject_id") @db.Uuid
  modelName     String       @map("model_name") @db.VarChar(150)
  modelVersion  String       @map("model_version") @db.VarChar(100)
  suggestion    Json
  confidence    Decimal
  humanDecision Json?        @map("human_decision")
  decidedBy     String?      @map("decided_by") @db.Uuid
  decidedAt     DateTime?    @map("decided_at") @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  org   Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study Study        @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([subjectType, subjectId])
  @@map("ai_decisions")
}

// ──────── Domain / Sub-Domain Master Module ────────
// Global reference/master data (no orgId, no RLS — same pattern as Role/
// ConsentPolicy) seeded from question-bank-v1.json's Domain/Sub-Domain
// hierarchy ONLY (not its Indicators/KPIs/Questions, which belong to the
// separately-owned Question Bank module). Consumed by the AI Override
// screen's domain/sub-domain dropdowns; never used during Need creation.
// Deactivate rather than delete — a retired domain/sub-domain must not
// vanish from historical AiDecision rows that already reference it by name.
model Domain {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  code         String   @unique @db.VarChar(64)
  name         String   @db.VarChar(200)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  subDomains SubDomain[]

  @@map("domains")
}

model SubDomain {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  domainId     String   @map("domain_id") @db.Uuid
  code         String   @unique @db.VarChar(64)
  name         String   @db.VarChar(200)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@map("sub_domains")
}

// ──────── Publish Survey + Generate QR / Citizen public flow ────────
// Tenant-scoped (org_id + RLS, same isolation pattern as Study/Need/
// Evidence) even though the citizen-facing routes that read/write
// CitizenOtpChallenge/SurveyResponse rows are unauthenticated — those
// routes resolve the owning org from the PublicSurveyLink token first
// (cross-org SELECT via the cnap_supervisor connection, same technique
// TenantPrismaService.runAsSupervisor already uses), then write through
// TenantPrismaService.runAsOrg(resolvedOrgId, ...), which is exactly how
// the org-creation bootstrap path (no signed-in actor yet either) already
// writes under RLS.
model PublicSurveyLink {
  id        String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  studyId   String    @map("study_id") @db.Uuid
  // User-facing name ("Baseline Survey", "Village A Outreach") — the only
  // identifier shown anywhere in the UI; unique per Study (not globally) so
  // two different Studies can each have their own "Baseline Survey" link.
  // Required, trimmed, max 150 chars — enforced at the service layer since
  // Postgres has no built-in trim-then-check-blank constraint.
  label     String    @db.VarChar(150)
  // Opaque public-URL token (/public/survey/:token) — never the raw study
  // id, so a citizen link can be revoked/rotated independently of the Study.
  token     String    @unique @db.VarChar(64)
  createdBy String    @map("created_by") @db.Uuid
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org                    Organisation            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study                  Study                   @relation(fields: [studyId], references: [id], onDelete: Cascade)
  otpChallenges          CitizenOtpChallenge[]
  responses              SurveyResponse[]
  responseQualityResults ResponseQualityResult[]
  aiSummaries            AiSummary[]
  priorityScores         PriorityScore[]

  @@unique([studyId, label])
  @@index([orgId])
  @@index([studyId])
  @@map("public_survey_links")
}

// Provider-agnostic OTP delivery (current implementation may send via
// email; swapping to SMS later must not require a contract change) — see
// RIO-FR-Add-02. `codeHash` only, never the plaintext code at rest.
model CitizenOtpChallenge {
  id           String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  surveyLinkId String    @map("survey_link_id") @db.Uuid
  contact      String    @db.VarChar(320)
  codeHash     String    @map("code_hash") @db.VarChar(255)
  attempts     Int       @default(0)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  verifiedAt   DateTime? @map("verified_at") @db.Timestamptz(6)
  // Set once this challenge has been used to successfully submit a
  // SurveyResponse — a verified-but-already-consumed challenge can no
  // longer submit again, closing off resubmission via a still-known
  // challengeId (see CitizenService.submitResponse()).
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org        Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  surveyLink PublicSurveyLink @relation(fields: [surveyLinkId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([surveyLinkId])
  @@map("citizen_otp_challenges")
}

// Generic response row — Response Quality, AI Summary, and Priority
// Dashboard all read from this same table, seeded or real alike.
model SurveyResponse {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  studyId      String   @map("study_id") @db.Uuid
  surveyLinkId String   @map("survey_link_id") @db.Uuid
  contactName  String?  @map("contact_name") @db.VarChar(200)
  contact      String   @db.VarChar(320)
  answers      Json
  submittedAt  DateTime @default(now()) @map("submitted_at") @db.Timestamptz(6)

  org            Organisation            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study          Study                   @relation(fields: [studyId], references: [id], onDelete: Cascade)
  surveyLink     PublicSurveyLink        @relation(fields: [surveyLinkId], references: [id], onDelete: Cascade)
  qualityResults ResponseQualityResult[]

  @@unique([studyId, contact])
  @@index([orgId])
  @@index([studyId])
  @@index([surveyLinkId])
  @@map("survey_responses")
}

// ──────── Response Quality + AI Summary ────────
// Same placeholder pattern as ai-decisions: a pure function computes canned
// output, a real service reads real SurveyResponse rows and writes a real
// result row here. "Response Quality" measures the responses themselves
// (completeness, confidence, duplicates) — not survey design.
enum ConfidenceFlag {
  standard
  low
}

model ResponseQualityResult {
  id                String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId             String         @map("org_id") @db.Uuid
  studyId           String         @map("study_id") @db.Uuid
  // Null = computed from every Survey Link's responses ("Consolidated"
  // scope); set = computed from just that one link's responses. Lets the
  // Study Insights "Survey Scope" selector read back exactly the scope it
  // wrote, instead of always mixing every link's results together.
  surveyLinkId      String?        @map("survey_link_id") @db.Uuid
  surveyResponseId  String         @map("survey_response_id") @db.Uuid
  completenessScore Int            @map("completeness_score")
  missingFields     String[]       @map("missing_fields")
  confidenceFlag    ConfidenceFlag @map("confidence_flag")
  isDuplicate       Boolean        @default(false) @map("is_duplicate")
  duplicateOfId     String?        @map("duplicate_of_id") @db.Uuid
  assessedAt        DateTime       @default(now()) @map("assessed_at") @db.Timestamptz(6)

  org            Organisation      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study          Study             @relation(fields: [studyId], references: [id], onDelete: Cascade)
  surveyLink     PublicSurveyLink? @relation(fields: [surveyLinkId], references: [id], onDelete: Cascade)
  surveyResponse SurveyResponse    @relation(fields: [surveyResponseId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([studyId])
  @@index([surveyLinkId])
  @@map("response_quality_results")
}

// One row per generation (history retained); GET reads the latest per scope.
model AiSummary {
  id            String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  studyId       String   @map("study_id") @db.Uuid
  // Same null = Consolidated / set = single-link convention as
  // ResponseQualityResult.surveyLinkId above.
  surveyLinkId  String?  @map("survey_link_id") @db.Uuid
  summaryText   String   @map("summary_text")
  responseCount Int      @map("response_count")
  generatedAt   DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)

  org        Organisation      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study      Study             @relation(fields: [studyId], references: [id], onDelete: Cascade)
  surveyLink PublicSurveyLink? @relation(fields: [surveyLinkId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([studyId])
  @@index([surveyLinkId])
  @@map("ai_summaries")
}

// ──────── Priority Dashboard + Explainable Score ────────
// TODO(RIO-Priority): placeholder scoring only — see
// priority/priority.placeholder.ts. Real methodology scoring workbook
// replaces just that function later; this table/API shape doesn't change.
enum PriorityLevel {
  critical
  high
  medium
  low
}

model PriorityScore {
  id           String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  studyId      String        @map("study_id") @db.Uuid
  // Same null = Consolidated / set = single-link convention as
  // ResponseQualityResult.surveyLinkId above.
  surveyLinkId String?       @map("survey_link_id") @db.Uuid
  overallScore Int           @map("overall_score")
  level        PriorityLevel
  gapType      String        @map("gap_type") @db.VarChar(50)
  // 9-factor breakdown from scope.md §8 (severity, affected population,
  // service availability gap, urgency, data confidence, frequency,
  // geographic coverage, vulnerable groups/equity, strategic alignment).
  factors      Json
  cycleNote    String?       @map("cycle_note") @db.VarChar(200)
  scoredAt     DateTime      @default(now()) @map("scored_at") @db.Timestamptz(6)

  org        Organisation      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study      Study             @relation(fields: [studyId], references: [id], onDelete: Cascade)
  surveyLink PublicSurveyLink? @relation(fields: [surveyLinkId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([studyId])
  @@index([surveyLinkId])
  @@map("priority_scores")
}

// ──────── Sharing Requests, Approval, Shared Reports ────────
// Deliberately NOT org-scoped RLS like every other tenant table: a sharing
// request is inherently visible to TWO orgs (the owner being asked, and the
// requester asking) plus the cross-entity Center Supervisor — a single
// `org_id = current_org_id` policy can't express "visible to either side."
// Authorization here is enforced at the service layer instead (ownerOrgId
// must equal caller's org to approve/reject; requestingOrgId must equal
// caller's org to create), same spirit as Domain/SubDomain's no-RLS
// reference-table pattern, just app-enforced instead of RLS-enforced.
enum SharingStatus {
  pending
  approved
  rejected
  expired
}

model SharingRequest {
  id              String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  ownerOrgId      String        @map("owner_org_id") @db.Uuid
  requestingOrgId String        @map("requesting_org_id") @db.Uuid
  studyId         String        @map("study_id") @db.Uuid
  status          SharingStatus @default(pending)
  requestedBy     String        @map("requested_by") @db.Uuid
  requestedAt     DateTime      @default(now()) @map("requested_at") @db.Timestamptz(6)
  decidedBy       String?       @map("decided_by") @db.Uuid
  decidedAt       DateTime?     @map("decided_at") @db.Timestamptz(6)
  note            String?       @db.VarChar(1000)

  ownerOrg      Organisation @relation("SharingRequestsOwned", fields: [ownerOrgId], references: [id], onDelete: Cascade)
  requestingOrg Organisation @relation("SharingRequestsMade", fields: [requestingOrgId], references: [id], onDelete: Cascade)
  study         Study        @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([ownerOrgId])
  @@index([requestingOrgId])
  @@index([studyId])
  @@map("sharing_requests")
}

// ──────── Reports Module (RPT-01..RPT-13) ────────
// One flexible report engine, not 13 bespoke tables — `reportType` is a
// discriminator, `filters`/`content` carry the type-specific shape.
// RPT-12 (Report Sharing Status) is a read view over SharingRequest, not
// separate data — its `content` is populated from that table at generation
// time, not stored redundantly elsewhere.
enum ReportType {
  RPT01
  RPT02
  RPT03
  RPT04
  RPT05
  RPT06
  RPT07
  RPT08
  RPT09
  RPT10
  RPT11
  RPT12
  RPT13
}

enum ReportStatus {
  draft
  approved
  rejected
}

model Report {
  id          String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId       String       @map("org_id") @db.Uuid
  reportType  ReportType   @map("report_type")
  status      ReportStatus @default(draft)
  title       String       @db.VarChar(300)
  // Only set for study-scoped types (e.g. RPT-01 Individual Study Report);
  // null for org-wide aggregate types (e.g. RPT-02 Collective Dashboard).
  studyId     String?      @map("study_id") @db.Uuid
  filters     Json
  content     Json
  generatedBy String       @map("generated_by") @db.Uuid
  generatedAt DateTime     @default(now()) @map("generated_at") @db.Timestamptz(6)
  reviewedBy  String?      @map("reviewed_by") @db.Uuid
  reviewedAt  DateTime?    @map("reviewed_at") @db.Timestamptz(6)

  org   Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study Study?       @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([reportType])
  @@map("reports")
}

// ──────── Methodology Configuration ────────
// Global reference/master data (no orgId, no RLS — same pattern as
// Role/ConsentPolicy/Domain), single-row: the platform-wide methodology
// baseline (priority thresholds, confidence-flag rule, version label) that
// Priority Dashboard and Response Quality read at scoring/assessment time
// instead of hardcoding these numbers in the placeholder functions. Domains/
// Subdomains (see Domain/SubDomain models above) are the other half of this
// same "Methodology Configuration" screen.
enum MethodologyStatus {
  draft
  published
}

model MethodologyConfig {
  id                     String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  // Free-text version label the reviewer sets (e.g. "v1.0 - Approved
  // implementation baseline") — mirrors question-bank-v1.json's own
  // _meta.versionLabel convention, not a semver the app enforces.
  version                String            @db.VarChar(100)
  status                 MethodologyStatus @default(draft)
  publishedBy            String?           @map("published_by") @db.Uuid
  publishedAt            DateTime?         @map("published_at") @db.Timestamptz(6)
  // Priority Dashboard's placeholder scoring thresholds — see
  // priority.placeholder.ts. Shape: { criticalSeverity, highSeverity,
  // mediumSeverity, equityHighSeverity }.
  priorityThresholds     Json              @map("priority_thresholds")
  // The 9 configurable Priority Scoring factors from scope.md §8 — each
  // { key, label, weight }. `key`/`label` are the methodology's fixed
  // vocabulary (scorePriority keys off `key`); only `weight` is meant to be
  // edited from the Methodology Configuration screen.
  priorityFactorWeights  Json              @map("priority_factor_weights")
  // Response Quality's confidence-flag rule — see
  // response-quality.placeholder.ts. Shape: { dontKnowRatioThreshold,
  // minRespondentsForStandardConfidence }.
  confidenceFlagSettings Json              @map("confidence_flag_settings")
  updatedAt              DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy              String?           @map("updated_by") @db.Uuid

  @@map("methodology_configs")
}

// ──────── Question Bank / AI Survey Builder ────────

// Global reference/master data (no org_id, no RLS — same pattern as
// Domain/SubDomain) — imported from the question bank dataset via
// prisma/import-questions.ts, read-only to cnap_app at runtime.
model Question {
  id               String  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  questionId       String  @unique @map("question_id") @db.VarChar(64)
  domain           String  @db.VarChar(120)
  subDomain        String  @map("sub_domain") @db.VarChar(120)
  indicator        String? @db.VarChar(200)
  kpi              String? @db.VarChar(200)
  questionText     String  @map("question_text")
  answerType       String  @map("answer_type") @db.VarChar(64)
  answerOptions    Json?   @map("answer_options")
  requiredOptional String  @map("required_optional") @db.VarChar(64)
  usedInMvp        Boolean @default(true) @map("used_in_mvp")
  reportMapping    String? @map("report_mapping")

  surveyQuestions SurveyQuestion[]

  @@index([domain, subDomain])
  @@map("questions")
}

// One row per AI Classification run against a Study's problem statement —
// same "suggestion, kept forever even after a human overrides it" shape as
// the older AiDecision model, but scoped to this feature's own
// domain/sub-domain/question-suggestion shape rather than AiDecision's.
model AiSuggestion {
  id                   String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId                String   @map("org_id") @db.Uuid
  studyId              String   @map("study_id") @db.Uuid
  type                 String   @db.VarChar(64)
  inputHash            String?  @map("input_hash") @db.VarChar(64)
  suggestedDomain      String?  @map("suggested_domain") @db.VarChar(120)
  suggestedSubDomain   String?  @map("suggested_sub_domain") @db.VarChar(120)
  suggestedQuestionIds Json?    @map("suggested_question_ids")
  confidence           Decimal  @db.Decimal(5, 2)
  reason               String
  modelName            String   @map("model_name") @db.VarChar(150)
  promptVersion        String   @map("prompt_version") @db.VarChar(64)
  rawResponse          Json?    @map("raw_response")
  createdBy            String   @map("created_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org           Organisation    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study         Study           @relation(fields: [studyId], references: [id], onDelete: Cascade)
  humanDecisions HumanDecision[]

  @@index([orgId])
  @@index([studyId])
  @@map("ai_suggestions")
}

// A human reviewer's decision on an AiSuggestion — approve as-is or
// override with a final domain/sub-domain/question set. aiSuggestionId is
// nullable/SetNull so removing a suggestion (shouldn't normally happen)
// can't take the decision record down with it.
model HumanDecision {
  id               String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  studyId          String   @map("study_id") @db.Uuid
  aiSuggestionId   String?  @map("ai_suggestion_id") @db.Uuid
  decision         String   @db.VarChar(64)
  finalDomain      String?  @map("final_domain") @db.VarChar(120)
  finalSubDomain   String?  @map("final_sub_domain") @db.VarChar(120)
  finalQuestionIds Json?    @map("final_question_ids")
  reason           String?
  decidedBy        String   @map("decided_by") @db.Uuid
  decidedAt        DateTime @default(now()) @map("decided_at") @db.Timestamptz(6)

  org          Organisation  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study        Study         @relation(fields: [studyId], references: [id], onDelete: Cascade)
  aiSuggestion AiSuggestion? @relation(fields: [aiSuggestionId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([studyId])
  @@map("human_decisions")
}

// The Survey Builder's own per-Study survey — a curated ordered subset of
// Questions, distinct from the Publish Survey/Citizen flow's PublicSurveyLink
// (that flow is the placeholder fixed-question-set QR flow; this is the
// eventual real per-Study question set once a human finalizes it).
model Survey {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  studyId   String   @map("study_id") @db.Uuid
  title     String   @db.VarChar(300)
  status    String   @db.VarChar(64)
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org             Organisation           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  study           Study                  @relation(fields: [studyId], references: [id], onDelete: Cascade)
  surveyQuestions SurveyQuestion[]
  builderResponses SurveyBuilderResponse[]

  @@index([orgId])
  @@index([studyId])
  @@map("surveys")
}

// Two kinds of rows, discriminated by whether `questionId` is set:
//   - Question Bank question: questionId set, customText/customAnswerType
//     null. Text/type/options/indicator/KPI/domain all come from the
//     Question row — never editable here, only order/isRequired are.
//   - Additional (open-ended) question: questionId null, customText set.
//     A Research Officer's study-specific question, never written into the
//     `questions` (Question Bank) table — it belongs only to this Survey.
//     No KPI/indicator/report-mapping/domain — those are Question Bank
//     concepts this kind of question deliberately has none of.
// Both kinds share one `order` sequence so the two Survey Builder UI
// sections (AI Recommended, Additional) still save as a single ordered list.
model SurveyQuestion {
  id               String  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  surveyId         String  @map("survey_id") @db.Uuid
  questionId       String? @map("question_id") @db.Uuid
  customText       String? @map("custom_text")
  customAnswerType String? @map("custom_answer_type") @db.VarChar(64)
  // Options list for an additional question of type multiple_choice/
  // checkbox — null for every other additional-question type, and always
  // null for Question Bank questions (those use `questions.answer_options`).
  customOptions    Json?   @map("custom_options")
  order            Int
  isRequired       Boolean @default(true) @map("is_required")

  survey   Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@index([questionId])
  @@map("survey_questions")
}

// NOTE: this is deliberately NOT named/mapped "survey_responses" — that
// table name is already taken by the Publish Survey/Citizen flow's
// SurveyResponse model (org/study/survey-link/contact-scoped, backs the
// live citizen OTP submission flow, Response Quality, Priority, Reports).
// The original migration for this feature also called its table
// "survey_responses", which would collide outright (CREATE TABLE would
// fail) since that table already exists. Renamed here — and in this
// feature's own migration.sql — to survey_builder_responses instead, since
// this is Survey Builder's own response shape (survey_id + answers only,
// no org/contact scoping), a genuinely different concept from the citizen
// flow's SurveyResponse.
model SurveyBuilderResponse {
  id          String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  surveyId    String   @map("survey_id") @db.Uuid
  answers     Json
  submittedAt DateTime @default(now()) @map("submitted_at") @db.Timestamptz(6)

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@map("survey_builder_responses")
}
