NODE_ENV=development
PORT=4000
# If your host's 5432 is already taken (e.g. a native PostgreSQL service), set
# DB_HOST_PORT=<port> here and update the two URLs below to match that port.
# If your host's 3000 is already taken, set API_HOST_PORT=<port> here — this
# only affects `docker compose up api`'s published host port.
# Owner role — used ONLY by the Prisma CLI (migrate/seed)
DATABASE_URL=postgresql://cnap_owner:cnap_owner_dev_pw@localhost:5432/cnap
# Restricted NOBYPASSRLS role — used by the running application
APP_DATABASE_URL=postgresql://cnap_app:cnap_app_dev_pw@localhost:5432/cnap
# Cross-org read-only role (NOBYPASSRLS) — used by the app's runAsSupervisor path
SUPERVISOR_DATABASE_URL=postgresql://cnap_supervisor:cnap_supervisor_dev_pw@localhost:5432/cnap
# JWT signing secret (min 32 chars) — set a strong random value per environment
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars
JWT_EXPIRES_IN=12h
# --- Encryption in transit (RIO-NFR-001) ---
# Set BOTH to serve HTTPS directly; otherwise the app serves HTTP and TLS is
# expected to be terminated by an ingress/reverse proxy in front of it.
# Generate a dev cert:
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout certs/dev-key.pem \
#     -out certs/dev-cert.pem -days 365 -subj "/CN=localhost"
# TLS_CERT_PATH=certs/dev-cert.pem
# TLS_KEY_PATH=certs/dev-key.pem
# Connect to Postgres over TLS (RIO-NFR-001). The compose db (db/Dockerfile)
# ships an SSL-enabled server, so this is on by default. Set false only when
# pointing at a Postgres without TLS.
DB_SSL=true
# Verify the Postgres server certificate. Defaults to false so the self-signed
# dev cert works out of the box (encryption without authentication). In
# production set this true — and point DB_SSL_CA at the CA/chain PEM if the
# server cert is not signed by a system-trusted CA — so the DB connection is
# authenticated and not exposed to MITM.
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=certs/db-ca.pem
LOG_LEVEL=info
# Frontend origin allowed to send credentialed (cookie) requests
CORS_ORIGIN=http://localhost:3000

# SMTP (nodemailer). Leave SMTP_HOST unset to disable email; signup then
# reveals the temp password in the response outside production only.
# SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=RIO <no-reply@rio.local>

# Opt-in double-submit CSRF (requires the frontend to echo rio_csrf as
# X-CSRF-Token). Keep false until the frontend cooperates / for same-site deploys.
CSRF_ENFORCE=false
