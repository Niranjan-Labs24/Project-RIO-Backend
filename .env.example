NODE_ENV=development
PORT=3000
# If your host's 5432 is already taken (e.g. a native PostgreSQL service), set
# DB_HOST_PORT=<port> here and update the two URLs below to match that port.
# If your host's 3000 is already taken, set API_HOST_PORT=<port> here — this
# only affects `docker compose up api`'s published host port.
# Owner role — used ONLY by the Prisma CLI (migrate/seed)
DATABASE_URL=postgresql://cnap_owner:cnap_owner_dev_pw@localhost:5432/cnap
# Restricted NOBYPASSRLS role — used by the running application
APP_DATABASE_URL=postgresql://cnap_app:cnap_app_dev_pw@localhost:5432/cnap
# Signs/verifies the session JWT (POST /auth/login, /auth/signup). Generate a
# real secret for anything beyond local dev, e.g.: openssl rand -base64 48
JWT_SECRET=dev-only-secret-change-me-before-any-shared-environment
# The frontend origin allowed to send credentialed (cookie-bearing) requests.
# Backend keeps its own default port (3000); the frontend dev server runs on
# 3001 instead of contesting it — override this if your frontend runs elsewhere.
CORS_ORIGIN=http://localhost:3001
# Emails the signup temporary password via Resend. Get a free key at
# resend.com -> API Keys. Leave unset to fall back to logging the temporary
# password (and returning it in the signup response outside production)
# instead of emailing it — see MailerService / AuthService.signup().
# RESEND_API_KEY=re_your_key_here
# Resend's shared test domain works with no setup/verification; swap to a
# verified domain once you have one.
MAIL_FROM="Rio <onboarding@resend.dev>"
LOG_LEVEL=info
